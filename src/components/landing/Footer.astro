---
// Footer - Simple y limpio
---

<footer class="py-10 px-6 border-t border-neutral-800">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-center gap-6">

      <!-- Logo y tagline -->
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-primary/20 flex items-center justify-center">
          <span class="material-icons-round text-primary text-lg">casino</span>
        </div>
        <span class="font-heading font-semibold text-neutral-50">BetSocial</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-neutral-400">
        <a href="#how-it-works" class="hover:text-neutral-50 transition-colors">Cómo funciona</a>
        <a href="#features" class="hover:text-neutral-50 transition-colors">Características</a>
        <a href="#" class="hover:text-neutral-50 transition-colors">Términos</a>
        <a href="#" class="hover:text-neutral-50 transition-colors">Privacidad</a>
      </div>

      <!-- Powered by Stellar -->
      <div class="flex items-center gap-2 text-sm text-neutral-500">
        <span>Powered by</span>
        <img src="/stellar-logo-small.png" alt="Stellar" class="w-4 h-4 invert opacity-60" />
        <span class="text-neutral-400">Stellar</span>
      </div>

    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-neutral-800 text-center text-sm text-neutral-500">
      © 2026 BetSocial. Hecho con ☕ para el Ideatón Build on Stellar Chile.
    </div>

  </div>
</footer>
